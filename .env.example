# Copy to .env and edit for your machine, or export these variables directly.
# The Python scripts read these environment variables as defaults; every path
# can still be overridden with the corresponding command-line flag.

# Local clone of this repository.
EOP012_PROJECT_ROOT="${PWD}"

# External working-data root. Keep raw NOAA files, staging files, and local
# database clusters here instead of committing them to Git.
EOP012_DATA_ROOT="${HOME}/eop012_data"

# EIA-860 2024 final ZIP downloaded from EIA.
EOP012_EIA860_ZIP="${EOP012_DATA_ROOT}/raw/eia860/intake/eia8602024.zip"

# Shared staging directory for generated CSVs before database load.
EOP012_STAGING_ROOT="${EOP012_DATA_ROOT}/staging"

# NOAA Global Hourly raw CSV/GZ cache used by the NOAA loaders.
EOP012_NOAA_GLOBAL_HOURLY_ROOT="${EOP012_DATA_ROOT}/raw/noaa/global-hourly"

# Colon-separated list of NOAA raw roots for inventory scans. Include every
# local cache root that may already contain station-year CSVs; otherwise the
# backfill manifest can plan duplicate AWS downloads.
EOP012_NOAA_RAW_ROOTS="${EOP012_NOAA_GLOBAL_HOURLY_ROOT}"

# NOAA station metadata download/cache path.
EOP012_STATION_HISTORY_CSV="${EOP012_DATA_ROOT}/raw/noaa/isd-history.csv"

# Optional legacy/source Postgres cluster used by the coverage-audit bridge.
EOP012_SOURCE_CLUSTER_PATH="${EOP012_DATA_ROOT}/postgres16_weather_build_5435"

# PostgreSQL client binary. Use an absolute path if psql is not on PATH.
EOP012_PSQL="psql"
